# این فایل را کپی کنید به .env.local و مقادیر واقعی را جایگزین کنید.
# .env.local هرگز نباید commit شود (در .gitignore قرار دارد).

# ---------------------------------------------------------------------------
# Google Sheets Backend (Apps Script Web App URL)
# راهنمای ساخت این مقادیر در README.md بخش «راه‌اندازی Google Sheet» است.
# ---------------------------------------------------------------------------
GOOGLE_SCRIPT_URL=
GOOGLE_SCRIPT_SECRET=

# ---------------------------------------------------------------------------
# Cloudinary
# از Dashboard اکانت Cloudinary خود بردارید.
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------------
# Auth / Session
# یک رشته‌ی تصادفی و طولانی برای امضای امن جلسه‌ی کاربر.
# با این دستور در ترمینال بسازید:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Telegram Mini App
# توکن را از @BotFather بگیرید (دستور /mybots -> انتخاب بات -> API Token).
# هرگز این توکن را در کد یا چت به اشتراک نگذارید.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# آدرس پایه‌ی سایت (برای ساخت لینک‌های اشتراک‌گذاری کارت و QR)
# در محلی: http://localhost:3000
# در Vercel: آدرس دامنه‌ی واقعی، مثلاً https://icard-username.vercel.app
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
